{
  "name": "grammar-pal",
  "displayName": "Grammar Pal",
  "version": "0.1.0",
  "description": "Live grammar/style underlines on any editable field, plus a corner pet that reacts to your errors.",
  "author": "Grammar Pal",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "plasmo build && node scripts/fix-underscore-files.mjs",
    "package": "plasmo package",
    "test": "vitest run src/lib/languagetool.test.ts",
    "test:harper:eval": "vitest run --reporter=verbose src/lib/harper.evaluation.test.ts"
  },
  "dependencies": {
    "harper.js": "^2.0.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "typescript": "5.3.3",
    "vitest": "^4.1.5"
  },
  "manifest": {
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://grammar-pal-polish.*.workers.dev/*"
    ],
    "content_security_policy": {
      "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    }
  }
}
